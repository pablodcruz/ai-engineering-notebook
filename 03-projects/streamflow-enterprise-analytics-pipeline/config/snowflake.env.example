# Copy this file to .env.snowflake and fill in local values.
# .env.snowflake is ignored by Git through the root .gitignore pattern.

SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=STREAMFLOW_AGENT
SNOWFLAKE_PASSWORD=your_local_password
SNOWFLAKE_ROLE=STREAMFLOW_ROLE
SNOWFLAKE_WAREHOUSE=STREAMFLOW_WH
SNOWFLAKE_DATABASE=STREAMFLOW_DB
SNOWFLAKE_SCHEMA=BRONZE
